{
  "expo": {
    "name": "PocketCash",
    "slug": "pocket-money-calculator",
    "version": "1.0.0",
    "description": "PocketCash is a free offline expense tracker, daily spending log, pocket money manager, and budget calculator. Track cash, log expenses with notes, see your balance update live, filter history by month or day, and export PDF reports. Auto-detects your currency. No account, no ads, no internet needed — your data stays on your phone.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F6F8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.khairul.pocketmoney",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.khairul.pocketmoney",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F6F8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "865d814f-b871-426f-8cff-21f605b037ae"
      }
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
